{
  "name": "aqualuxe-theme",
  "version": "1.0.0",
  "description": "Premium aquatic lifestyle WordPress theme with modular architecture",
  "main": "webpack.mix.js",
  "private": true,
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "NODE_ENV=production mix --production",
    "build": "npm run production",
    "clean": "rm -rf assets/dist/*",
    "lint:js": "eslint assets/src/js/**/*.js",
    "lint:css": "stylelint assets/src/scss/**/*.scss",
    "format": "prettier --write assets/src/**/*.{js,scss,css}",
    "test": "jest",
    "analyze": "npm run production -- --analyze"
  },
  "keywords": [
    "wordpress",
    "theme",
    "aquatic",
    "luxury",
    "woocommerce",
    "responsive",
    "modular"
  ],
  "author": "AquaLuxe Team",
  "license": "GPL-2.0-or-later",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "dependencies": {
    "alpinejs": "^3.13.3",
    "swiper": "^11.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "browser-sync": "^2.29.3",
    "browser-sync-webpack-plugin": "^2.3.0",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "file-loader": "^6.2.0",
    "imagemin": "^8.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^9.0.2",
    "imagemin-svgo": "^10.0.1",
    "imagemin-webp": "^8.0.0",
    "jest": "^29.7.0",
    "laravel-mix": "^6.0.49",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss": "^8.4.32",
    "postcss-loader": "^7.3.3",
    "prettier": "^3.1.1",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "stylelint": "^16.1.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "tailwindcss": "^3.3.6",
    "terser-webpack-plugin": "^5.3.9",
    "url-loader": "^4.1.1",
    "webpack": "^5.89.0",
    "webpack-bundle-analyzer": "^4.10.1",
    "webpack-cli": "^5.1.4"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "assets/src/js/**/*.js",
      "!assets/src/js/vendor/**/*.js"
    ]
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "prettier"
    ],
    "env": {
      "browser": true,
      "es2021": true,
      "jquery": true
    },
    "globals": {
      "wp": "readonly",
      "aqualuxe_ajax": "readonly",
      "wc_add_to_cart_params": "readonly"
    },
    "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "module"
    }
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard-scss"
    ],
    "rules": {
      "selector-class-pattern": null,
      "scss/at-rule-no-unknown": [
        true,
        {
          "ignoreAtRules": [
            "tailwind",
            "apply",
            "variants",
            "responsive",
            "screen"
          ]
        }
      ]
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100
  }
}
