{
  "name": "aqualuxe-theme",
  "version": "2.0.0",
  "description": "Premium modular WordPress theme for luxury aquatic solutions - Bringing elegance to aquatic life globally",
  "private": true,
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "build": "npm run production",
    "analyze": "npm run production -- --analyze",
    "lint:js": "eslint assets/src/js/**/*.js --fix",
    "lint:css": "stylelint assets/src/scss/**/*.scss --fix",
    "lint": "npm run lint:js && npm run lint:css",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf assets/dist/*"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 11",
    "not dead"
  ],
  "dependencies": {
    "@splidejs/splide": "^4.1.4",
    "gsap": "^3.12.2",
    "swiper": "^11.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "browser-sync": "^2.29.3",
    "browser-sync-webpack-plugin": "^2.3.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "eslint": "^8.56.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.1.1",
    "file-loader": "^6.2.0",
    "imagemin": "^8.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^9.0.2",
    "imagemin-svgo": "^10.0.1",
    "imagemin-webpack-plugin": "^2.4.2",
    "jest": "^29.7.0",
    "laravel-mix": "^6.0.49",
    "postcss": "^8.4.32",
    "resolve-url-loader": "^5.0.0",
    "rimraf": "^5.0.5",
    "sass": "^1.69.7",
    "sass-loader": "^13.3.3",
    "stylelint": "^16.1.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "tailwindcss": "^3.4.0",
    "webpack": "^5.89.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "wordpress",
    "theme",
    "aquatic",
    "luxury",
    "ecommerce",
    "woocommerce",
    "fish",
    "aquarium",
    "modular",
    "responsive",
    "accessibility"
  ],
  "author": "AquaLuxe Development Team",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/kasunvimarshana/aqualuxe-web"
  },
  "bugs": {
    "url": "https://github.com/kasunvimarshana/aqualuxe-web/issues"
  },
  "homepage": "https://aqualuxe.com"
}