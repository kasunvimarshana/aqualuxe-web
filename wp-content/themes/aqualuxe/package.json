{
  "name": "aqualuxe-theme",
  "version": "1.0.0",
  "description": "AquaLuxe - Premium WordPress Theme with modular, multitenant, multivendor architecture",
  "main": "webpack.mix.js",
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "build": "npm run production",
    "clean": "rimraf assets/dist/*",
    "lint:js": "eslint assets/src/js/**/*.js",
    "lint:css": "stylelint assets/src/css/**/*.css",
    "lint": "npm run lint:js && npm run lint:css",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.4",
    "@tailwindcss/typography": "^0.5.9",
    "autoprefixer": "^10.4.14",
    "axios": "^1.4.0",
    "browser-sync": "^2.29.3",
    "browser-sync-webpack-plugin": "^2.3.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.44.0",
    "jest": "^29.6.1",
    "laravel-mix": "^6.0.49",
    "postcss": "^8.4.24",
    "postcss-import": "^15.1.0",
    "resolve-url-loader": "^5.0.0",
    "rimraf": "^5.0.1",
    "sass": "^1.63.6",
    "sass-loader": "^13.3.2",
    "stylelint": "^15.10.1",
    "stylelint-config-standard": "^34.0.0",
    "tailwindcss": "^3.3.0",
    "webpack": "^5.88.1"
  },
  "dependencies": {
    "alpinejs": "^3.12.3",
    "aos": "^2.3.4",
    "@glidejs/glide": "^3.6.0",
    "swiper": "^10.0.4"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie <= 11"
  ],
  "keywords": [
    "wordpress",
    "theme",
    "woocommerce",
    "responsive",
    "multilingual",
    "multivendor",
    "multitenant",
    "aquarium",
    "luxury"
  ],
  "author": "Kasun Vimarshana",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/kasunvimarshana/aqualuxe-web"
  }
}