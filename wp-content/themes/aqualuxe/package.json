{
  "name": "aqualuxe-theme",
  "version": "1.0.0",
  "description": "Premium modular WordPress theme for aquatic life commerce and services",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development webpack --watch --mode=development",
    "build": "cross-env NODE_ENV=production webpack --mode=production",
    "build:dev": "cross-env NODE_ENV=development webpack --mode=development",
    "hot": "cross-env NODE_ENV=development webpack serve --hot --mode=development",
    "analyze": "cross-env NODE_ENV=production webpack-bundle-analyzer dist/js/app.js",
    "lint:js": "eslint assets/src/js/**/*.js --fix",
    "lint:css": "stylelint assets/src/scss/**/*.scss --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 11"
  ],
  "dependencies": {
    "@splidejs/splide": "^4.1.4",
    "gsap": "^3.12.2",
    "three": "^0.157.0",
    "swiper": "^11.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.3",
    "@babel/preset-env": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@types/three": "^0.157.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "eslint": "^8.53.0",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.5.3",
    "imagemin": "^8.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^9.0.2",
    "imagemin-svgo": "^10.0.1",
    "imagemin-webpack-plugin": "^2.4.2",
    "jest": "^29.7.0",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss": "^8.4.31",
    "postcss-loader": "^7.3.3",
    "postcss-preset-env": "^9.3.0",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "style-loader": "^3.3.3",
    "stylelint": "^15.11.0",
    "stylelint-config-standard-scss": "^11.1.0",
    "tailwindcss": "^3.3.5",
    "terser-webpack-plugin": "^5.3.9",
    "typescript": "^5.2.2",
    "url-loader": "^4.1.1",
    "webpack": "^5.89.0",
    "webpack-bundle-analyzer": "^4.9.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "webpack-manifest-plugin": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "wordpress",
    "theme",
    "aquatic",
    "ecommerce",
    "woocommerce",
    "fish",
    "aquarium",
    "three.js",
    "gsap",
    "modular"
  ],
  "author": "AquaLuxe Development Team",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/aqualuxe/theme"
  }
}
