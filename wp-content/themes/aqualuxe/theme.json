{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "primary", "color": "#0ea5e9", "name": "Primary" },
        { "slug": "foreground", "color": "#0f172a", "name": "Foreground" },
        { "slug": "background", "color": "#ffffff", "name": "Background" }
      ]
    },
    "spacing": { "units": ["px", "em", "rem", "%"], "blockGap": "1rem" },
    "typography": { "dropCap": false, "fontSizes": [
      { "slug": "small", "size": "0.875rem", "name": "Small" },
      { "slug": "medium", "size": "1rem", "name": "Medium" },
      { "slug": "large", "size": "1.25rem", "name": "Large" }
    ]}
  },
  "styles": {
    "color": { "text": "#0f172a", "background": "#ffffff" },
    "typography": { "fontFamily": "system-ui,-apple-system,Segoe UI,Roboto,Ubuntu,Cantarell,Noto Sans,sans-serif" }
  }
}
