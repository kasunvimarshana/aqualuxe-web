{
  "name": "aqualuxe-theme",
  "version": "2.0.0",
  "description": "Modern, modular WordPress theme for aquatic businesses - Enterprise edition with multivendor, multilingual, and multicurrency support",
  "author": {
    "name": "Kasun Vimarshana",
    "email": "kasunv.com@gmail.com",
    "url": "https://github.com/kasunvimarshana/aqualuxe-web"
  },
  "license": "GPL-2.0-or-later",
  "private": true,
  "keywords": [
    "wordpress-theme",
    "aquatic",
    "luxury",
    "woocommerce",
    "multivendor",
    "multilingual",
    "multicurrency",
    "tailwindcss",
    "modular",
    "enterprise"
  ],
  "homepage": "https://github.com/kasunvimarshana/aqualuxe-web",
  "repository": {
    "type": "git",
    "url": "https://github.com/kasunvimarshana/aqualuxe-web"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "mix",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "mix --production",
    "production": "mix --production",
    "build": "npm run production",
    "clean": "rm -rf assets/dist/*",
    "clean:node": "rm -rf node_modules package-lock.json",
    "fresh": "npm run clean && npm install",
    "lint:js": "eslint assets/src/js/**/*.js",
    "lint:css": "stylelint assets/src/**/*.{css,scss}",
    "lint": "npm run lint:js && npm run lint:css",
    "format": "prettier --write assets/src/**/*.{js,css,scss}",
    "analyze": "npm run production -- --analyze",
    "test": "jest",
    "test:watch": "jest --watch",
    "audit:fix": "npm audit fix --legacy-peer-deps"
  },
  "dependencies": {
    "alpinejs": "^3.13.3",
    "swiper": "^11.0.5",
    "aos": "^2.3.4",
    "lozad": "^1.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "browser-sync": "^2.29.3",
    "browser-sync-webpack-plugin": "^2.3.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "eslint": "^8.56.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "imagemin": "^8.0.1",
    "imagemin-gifsicle": "^7.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-optipng": "^8.0.0",
    "imagemin-pngquant": "^9.0.2",
    "imagemin-svgo": "^10.0.1",
    "jest": "^29.7.0",
    "laravel-mix": "^6.0.49",
    "postcss": "^8.4.32",
    "postcss-loader": "^7.3.4",
    "prettier": "^3.1.1",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.69.7",
    "sass-loader": "^13.3.3",
    "stylelint": "^16.1.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "tailwindcss": "^3.4.1",
    "webpack": "^5.89.0",
    "webpack-bundle-analyzer": "^4.10.1"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "browsers": [
              "> 1%",
              "last 2 versions",
              "not dead",
              "not ie <= 11"
            ]
          },
          "modules": false,
          "useBuiltIns": "usage",
          "corejs": 3
        }
      ]
    ],
    "plugins": [
      "@babel/plugin-proposal-class-properties",
      "@babel/plugin-syntax-dynamic-import"
    ]
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie <= 11"
  ],
  "eslintConfig": {
    "extends": [
      "standard"
    ],
    "env": {
      "browser": true,
      "node": true,
      "jquery": true
    },
    "globals": {
      "wp": "readonly",
      "jQuery": "readonly",
      "$": "readonly",
      "aqualuxeTheme": "readonly"
    }
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard",
      "stylelint-config-standard-scss"
    ],
    "rules": {
      "at-rule-no-unknown": [
        true,
        {
          "ignoreAtRules": [
            "tailwind",
            "apply",
            "layer",
            "variants",
            "responsive",
            "screen"
          ]
        }
      ]
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "bracketSpacing": true,
    "arrowParens": "avoid"
  }
}
