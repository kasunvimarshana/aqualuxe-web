{
  "name": "aqualuxe-theme",
  "version": "1.0.0",
  "description": "Premium AquaLuxe WordPress theme with modular architecture",
  "private": true,
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "build": "npm run production",
    "lint:js": "eslint assets/src/js --ext .js,.vue --fix",
    "lint:css": "stylelint assets/src/sass/**/*.scss --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "analyze": "mix --production --analyze",
    "clean": "rimraf assets/dist"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "cssnano": "^6.0.1",
    "eslint": "^8.54.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "file-loader": "^6.2.0",
    "imagemin": "^8.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^9.0.2",
    "imagemin-webpack-plugin": "^2.4.2",
    "jest": "^29.7.0",
    "laravel-mix": "^6.0.49",
    "postcss": "^8.4.31",
    "postcss-import": "^15.1.0",
    "postcss-loader": "^7.3.3",
    "rimraf": "^5.0.5",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "stylelint": "^15.11.0",
    "stylelint-config-standard-scss": "^11.1.0",
    "tailwindcss": "^3.3.6",
    "url-loader": "^4.1.1",
    "webpack-bundle-analyzer": "^4.9.1"
  },
  "dependencies": {
    "alpinejs": "^3.13.3",
    "@glidejs/glide": "^3.6.0",
    "lazysizes": "^5.3.2",
    "photoswipe": "^5.4.2",
    "vanilla-lazyload": "^17.8.5"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "keywords": [
    "wordpress",
    "theme",
    "woocommerce",
    "aquatic",
    "luxury",
    "ecommerce",
    "responsive",
    "multilingual",
    "modular"
  ],
  "author": "AquaLuxe Team",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/aqualuxe/theme.git"
  }
}
