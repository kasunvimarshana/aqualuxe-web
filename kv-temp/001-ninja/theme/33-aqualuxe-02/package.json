{
  "name": "aqualuxe",
  "version": "1.0.0",
  "description": "AquaLuxe WordPress + WooCommerce theme for luxury aquatic retail",
  "main": "index.js",
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "analyze": "mix --production --analyze",
    "lint": "eslint assets/src/js",
    "lint:fix": "eslint assets/src/js --fix",
    "stylelint": "stylelint assets/src/scss/**/*.scss",
    "stylelint:fix": "stylelint assets/src/scss/**/*.scss --fix",
    "critical": "node critical-css-simple.js",
    "imagemin": "node imagemin.js",
    "svg-sprite": "node svg-sprite.js",
    "test": "jest",
    "build": "npm run production && npm run critical",
    "build:analyze": "npm run analyze && npm run critical",
    "build:dev": "npm run development",
    "clean": "rimraf assets/css assets/js assets/images/sprite.svg",
    "prebuild": "npm run clean",
    "postbuild": "npm run imagemin && npm run svg-sprite"
  },
  "keywords": [
    "wordpress",
    "theme",
    "woocommerce",
    "tailwindcss",
    "ecommerce",
    "aquatic",
    "luxury"
  ],
  "author": "NinjaTech AI",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@fullhuman/postcss-purgecss": "^5.0.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.17",
    "browser-sync": "^3.0.2",
    "browser-sync-webpack-plugin": "^2.3.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "critical": "^5.1.1",
    "cross-env": "^7.0.3",
    "css-loader": "^6.10.0",
    "css-minimizer-webpack-plugin": "^6.0.0",
    "cssnano": "^6.0.3",
    "eslint": "^9.0.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "focus-visible": "^5.2.0",
    "glob": "^10.3.10",
    "imagemin": "^8.0.1",
    "imagemin-gifsicle": "^7.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-optipng": "^8.0.0",
    "imagemin-pngquant": "^9.0.2",
    "imagemin-svgo": "^10.0.1",
    "imagemin-webp": "^8.0.0",
    "jest": "^29.7.0",
    "laravel-mix": "^6.0.49",
    "laravel-mix-purgecss": "^6.0.0",
    "mini-css-extract-plugin": "^2.8.0",
    "mkdirp": "^3.0.1",
    "postcss": "^8.4.35",
    "postcss-import": "^16.0.1",
    "postcss-preset-env": "^9.3.0",
    "purgecss-webpack-plugin": "^5.0.0",
    "resolve-url-loader": "^5.0.0",
    "rimraf": "^5.0.5",
    "sass": "^1.71.1",
    "sass-loader": "^14.1.1",
    "style-loader": "^3.3.4",
    "stylelint": "^16.2.1",
    "stylelint-config-standard-scss": "^13.0.0",
    "svg-sprite": "^2.0.2",
    "tailwindcss": "^3.4.1",
    "terser-webpack-plugin": "^5.3.10",
    "webpack-assets-manifest": "^5.1.0",
    "webpack-bundle-analyzer": "^4.10.1",
    "webpack-merge": "^5.10.0",
    "webpack-remove-empty-scripts": "^1.0.4",
    "workbox-webpack-plugin": "^7.0.0"
  },
  "dependencies": {
    "focus-trap": "^7.5.4",
    "focus-visible": "^5.2.0",
    "intersection-observer": "^0.12.2",
    "jquery": "^3.7.1",
    "lazysizes": "^5.3.2",
    "lodash": "^4.17.21",
    "normalize.css": "^8.0.1",
    "swiper": "^11.0.5",
    "tippy.js": "^6.3.7",
    "whatwg-fetch": "^3.6.20"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie <= 11"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}