{
  "name": "aqualuxe-theme",
  "version": "1.0.0",
  "description": "AquaLuxe Premium WordPress Theme Asset Build System",
  "private": true,
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "build": "npm run production",
    "lint:js": "eslint assets/src/js --ext .js,.jsx,.ts,.tsx",
    "lint:css": "stylelint 'assets/src/sass/**/*.{css,scss}'",
    "lint": "npm run lint:js && npm run lint:css",
    "test": "jest",
    "test:watch": "jest --watch",
    "analyze": "npm run production -- --analyze"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.6",
    "@tailwindcss/typography": "^0.5.10",
    "@types/alpinejs": "^3.13.0",
    "@types/jquery": "^3.5.24",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "alpinejs": "^3.13.1",
    "autoprefixer": "^10.4.16",
    "axios": "^1.5.0",
    "babel-jest": "^29.7.0",
    "css-loader": "^6.8.1",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "gsap": "^3.12.2",
    "jest": "^29.7.0",
    "laravel-mix": "^6.0.49",
    "postcss": "^8.4.31",
    "prettier": "^3.0.3",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.68.0",
    "sass-loader": "^13.3.2",
    "stylelint": "^15.10.3",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-standard": "^34.0.0",
    "swiper": "^10.3.1",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "jquery": "^3.7.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "wordpress",
    "theme",
    "woocommerce",
    "aquatic",
    "luxury",
    "responsive",
    "tailwind"
  ],
  "author": "AquaLuxe Team",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/aqualuxe/aqualuxe-theme.git"
  }
}
