{
  "name": "aqualuxe-theme",
  "version": "1.0.0",
  "private": true,
  "description": "AquaLuxe WordPress theme build system",
  "scripts": {
    "dev": "mix",
    "watch": "mix watch",
    "build": "cross-env NODE_ENV=production mix --production",
    "lint:js": "eslint assets/src/js --ext .js,.ts",
    "lint:css": "stylelint \"assets/src/**/*.{css,scss}\"",
    "test": "vitest run",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.1.6",
    "laravel-mix": "^6.0.49",
    "laravel-mix-versionhash": "^2.0.1",
    "postcss": "^8.4.41",
    "postcss-import": "^16.1.0",
    "sass": "^1.77.6",
    "sass-loader": "^13.3.3",
    "stylelint": "^16.8.1",
    "stylelint-config-standard": "^36.0.0",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
