{
  "name": "aqualuxe",
  "version": "1.0.0",
  "description": "AquaLuxe - Premium WordPress theme with modular, responsive, and e-commerce ready architecture",
  "main": "index.js",
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "build": "npm run production"
  },
  "keywords": [
    "wordpress",
    "theme",
    "responsive",
    "ecommerce",
    "woocommerce",
    "multilingual",
    "multicurrency"
  ],
