{
    "name": "aqualuxe-theme",
    "version": "1.0.0",
    "description": "AquaLuxe - Premium WordPress Theme for Aquatic Commerce",
    "author": "Kasun Vimarshana",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "wordpress",
        "theme",
        "woocommerce",
        "aquatic",
        "e-commerce",
        "multilingual",
        "multicurrency",
        "responsive"
    ],
    "homepage": "https://github.com/kasunvimarshana/aqualuxe-web",
    "repository": {
        "type": "git",
        "url": "https://github.com/kasunvimarshana/aqualuxe-web.git"
    },
    "scripts": {
        "dev": "mix",
        "watch": "mix watch",
        "watch-poll": "mix watch -- --watch-options-poll=1000",
        "hot": "mix watch --hot",
        "build": "mix --production",
        "prod": "npm run build",
        "clean": "rimraf assets/dist",
        "lint:css": "stylelint 'assets/src/**/*.{css,scss}'",
        "lint:js": "eslint 'assets/src/**/*.js'",
        "test": "phpunit",
        "test:watch": "phpunit --watch"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/typography": "^0.5.9",
        "autoprefixer": "^10.4.14",
        "browser-sync": "^2.29.3",
        "browser-sync-webpack-plugin": "^2.3.0",
        "cross-env": "^7.0.3",
        "laravel-mix": "^6.0.49",
        "postcss": "^8.4.24",
        "resolve-url-loader": "^5.0.0",
        "rimraf": "^5.0.1",
        "sass": "^1.63.6",
        "sass-loader": "^13.3.2",
        "tailwindcss": "^3.3.2"
    },
    "browserslist": [
        "> 1%",
        "last 2 versions",
        "not dead"
    ],
    "engines": {
        "node": ">=14.0.0",
        "npm": ">=6.0.0"
    }
}