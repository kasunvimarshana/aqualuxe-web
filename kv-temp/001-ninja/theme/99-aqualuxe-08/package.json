{
  "name": "aqualuxe-theme",
  "version": "1.0.0",
  "description": "AquaLuxe - Premium WordPress theme with modular architecture",
  "keywords": [
    "wordpress",
    "theme",
    "woocommerce",
    "multitenant",
    "multivendor",
    "multilingual",
    "multicurrency"
  ],
  "author": "Kasun Vimarshana",
  "license": "GPL-2.0-or-later",
  "private": true,
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "lint:css": "stylelint 'assets/src/sass/**/*.scss'",
    "lint:js": "eslint 'assets/src/js/**/*.js'",
    "lint": "npm run lint:css && npm run lint:js",
    "format": "prettier --write 'assets/src/**/*.{js,scss,css}'",
    "build": "npm run production",
    "clean": "rimraf assets/css assets/js assets/fonts assets/images/dist assets/mix-manifest.json"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "autoprefixer": "^10.4.16",
    "browser-sync": "^2.29.3",
    "browser-sync-webpack-plugin": "^2.3.0",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^6.8.1",
    "eslint": "^8.50.0",
    "file-loader": "^6.2.0",
    "imagemin": "^8.0.1",
    "imagemin-gifsicle": "^7.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^9.0.2",
    "imagemin-svgo": "^10.0.1",
    "imagemin-webpack-plugin": "^2.4.2",
    "laravel-mix": "^6.0.49",
    "postcss": "^8.4.31",
    "prettier": "^3.0.3",
    "resolve-url-loader": "^5.0.0",
    "rimraf": "^5.0.5",
    "sass": "^1.69.0",
    "sass-loader": "^13.3.2",
    "stylelint": "^15.10.3",
    "stylelint-config-standard-scss": "^11.0.0",
    "tailwindcss": "^3.3.0",
    "url-loader": "^4.1.1",
    "webpack": "^5.88.0",
    "webpack-assets-manifest": "^5.1.0"
  },
  "dependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "jquery": "^3.7.1",
    "swiper": "^10.3.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
