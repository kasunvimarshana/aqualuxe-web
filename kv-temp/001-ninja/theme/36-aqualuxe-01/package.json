{
  "name": "aqualuxe",
  "version": "1.0.0",
  "description": "AquaLuxe - Premium WordPress Theme for Aquatic Businesses",
  "author": "AquaLuxe",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "build": "npm run production",
    "lint:js": "eslint assets/src/js/**/*.js",
    "lint:css": "stylelint assets/src/css/**/*.css assets/src/scss/**/*.scss",
    "lint:php": "composer run-script lint",
    "format:js": "eslint --fix assets/src/js/**/*.js",
    "format:css": "stylelint --fix assets/src/css/**/*.css assets/src/scss/**/*.scss",
    "format": "npm run format:js && npm run format:css",
    "test": "composer run-script test",
    "e2e": "playwright test",
    "package": "bash bin/package.sh",
    "clean": "rimraf assets/dist"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie <= 11"
  ],
  "devDependencies": {
    "@babel/core": "^7.22.5",
    "@babel/preset-env": "^7.22.5",
    "@playwright/test": "^1.35.1",
    "autoprefixer": "^10.4.14",
    "browser-sync": "^2.29.3",
    "browser-sync-webpack-plugin": "^2.3.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.43.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "file-loader": "^6.2.0",
    "laravel-mix": "^6.0.49",
    "postcss": "^8.4.24",
    "postcss-import": "^15.1.0",
    "prettier": "^2.8.8",
    "resolve-url-loader": "^5.0.0",
    "rimraf": "^5.0.1",
    "sass": "^1.63.6",
    "sass-loader": "^13.3.2",
    "stylelint": "^15.9.0",
    "stylelint-config-standard": "^33.0.0",
    "tailwindcss": "^3.3.2",
    "url-loader": "^4.1.1"
  },
  "dependencies": {
    "alpinejs": "^3.12.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}