{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1100px"
    },
    "custom": {
      "a11y": {
        "focusOutline": "2px solid #0a84ff"
      }
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vw", "vh"]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, Noto Sans, Helvetica, Arial, Apple Color Emoji, Segoe UI Emoji",
          "name": "System Sans",
          "slug": "system-sans"
        }
      ],
      "fluid": true
    },
    "color": {
      "palette": [
        { "slug": "primary", "color": "#0a84ff", "name": "Primary" },
        { "slug": "secondary", "color": "#0b3954", "name": "Secondary" },
        { "slug": "accent", "color": "#ff7f50", "name": "Accent" },
        { "slug": "neutral-0", "color": "#ffffff", "name": "White" },
        { "slug": "neutral-900", "color": "#111827", "name": "Black" }
      ]
    }
  },
  "styles": {
    "elements": {
      "link": {
        ":hover": { "typography": { "textDecoration": "underline" } }
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)",
      "lineHeight": "1.6"
    }
  }
}
