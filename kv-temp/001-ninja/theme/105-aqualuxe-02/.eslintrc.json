{
  "env": {
    "browser": true,
    "es2021": true,
    "jquery": true,
    "serviceworker": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "prettier"
  ],
  "rules": {
    "prettier/prettier": "error",
    "no-console": "warn",
    "no-debugger": "error",
    "no-unused-vars": "warn",
    "prefer-const": "error",
    "no-var": "error",
    "eqeqeq": "error",
    "curly": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-script-url": "error",
    "camelcase": [
      "error", 
      {
        "properties": "never",
        "ignoreDestructuring": true,
        "ignoreImports": true,
        "allow": ["aqualuxe_admin", "aqualuxe_ajax", "aqualuxe_data", "aqualuxe_bookings", "aqualuxe_events", "aqualuxe_dark_mode", "aqualuxe_multilingual", "aqualuxe_services"]
      }
    ]
  },
  "globals": {
    "wp": "readonly",
    "jQuery": "readonly",
    "$": "readonly",
    "aqualuxe": "readonly",
    "aqualuxeAjax": "readonly",
    "aqualuxeData": "readonly",
    "aqualuxe_admin": "readonly",
    "aqualuxe_ajax": "readonly",
    "aqualuxe_bookings": "readonly",
    "aqualuxe_events": "readonly",
    "aqualuxe_dark_mode": "readonly",
    "aqualuxe_multilingual": "readonly",
    "aqualuxe_services": "readonly",
    "clients": "readonly",
    "importScripts": "readonly",
    "workbox": "readonly",
    "gtag": "readonly"
  },
  "ignorePatterns": [
    "assets/dist/**",
    "node_modules/**",
    "*.min.js"
  ]
}