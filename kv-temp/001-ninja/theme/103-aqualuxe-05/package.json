{
  "name": "aqualuxe-theme",
  "version": "1.0.0",
  "description": "AquaLuxe WordPress Theme - Bringing elegance to aquatic life – globally",
  "main": "index.js",
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "build": "npm run production",
    "lint:css": "stylelint 'assets/src/**/*.{css,scss}'",
    "lint:js": "eslint assets/src/js/**/*.js",
    "lint": "npm run lint:css && npm run lint:js",
    "clean": "rimraf assets/dist",
    "analyze": "npm run production -- --analyze"
  },
  "keywords": [
    "wordpress",
    "theme",
    "woocommerce",
    "aquarium",
    "luxury",
    "responsive"
  ],
  "author": "AquaLuxe Development Team",
  "license": "GPL-2.0+",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.6",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "browser-sync": "^2.29.3",
    "browser-sync-webpack-plugin": "^2.3.0",
    "css-loader": "^6.8.1",
    "cssnano": "^6.0.1",
    "eslint": "^8.52.0",
    "eslint-config-standard": "^17.1.0",
    "file-loader": "^6.2.0",
    "laravel-mix": "^6.0.49",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss": "^8.4.31",
    "postcss-import": "^15.1.0",
    "postcss-loader": "^7.3.3",
    "resolve-url-loader": "^5.0.0",
    "rimraf": "^5.0.5",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "tailwindcss": "^3.3.5",
    "url-loader": "^4.1.1",
    "webpack": "^5.89.0",
    "webpack-bundle-analyzer": "^4.9.1"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.17",
    "alpinejs": "^3.13.2",
    "aos": "^2.3.4",
    "glightbox": "^3.2.0",
    "gsap": "^3.12.2",
    "intersection-observer": "^0.12.2",
    "lodash": "^4.17.21",
    "swiper": "^11.0.3"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}