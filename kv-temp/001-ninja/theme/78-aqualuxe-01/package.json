{
  "name": "aqualuxe-theme",
  "version": "1.0.0",
  "description": "Premium WordPress theme for aquatic retail and services",
  "main": "webpack.mix.js",
  "scripts": {
    "dev": "npx mix",
    "development": "npx mix",
    "watch": "npx mix watch",
    "watch-poll": "npx mix watch -- --watch-options-poll=1000",
    "hot": "npx mix watch --hot",
    "prod": "npx mix --production",
    "production": "npx mix --production",
    "build": "npx mix --production",
    "lint": "eslint assets/src/js --ext .js",
    "lint:fix": "eslint assets/src/js --ext .js --fix",
    "format": "prettier --write \"assets/src/**/*.{js,css,scss}\""
  },
  "keywords": [
    "wordpress",
    "theme",
    "aquatic",
    "ecommerce",
    "woocommerce",
    "responsive"
  ],
  "author": "AquaLuxe Development Team",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "laravel-mix": "^6.0.49",
    "postcss": "^8.4.31",
    "prettier": "^3.0.3",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.69.0",
    "sass-loader": "^13.3.2",
    "tailwindcss": "^3.3.5"
  },
  "dependencies": {
    "alpinejs": "^3.13.1",
    "swiper": "^10.3.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
