{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "primary",
          "color": "#0e7490",
          "name": "Primary"
        },
        {
          "slug": "secondary",
          "color": "#0891b2",
          "name": "Secondary"
        },
        {
          "slug": "accent",
          "color": "#06b6d4",
          "name": "Accent"
        },
        {
          "slug": "dark",
          "color": "#0f172a",
          "name": "Dark"
        },
        {
          "slug": "light",
          "color": "#f8fafc",
          "name": "Light"
        },
        {
          "slug": "white",
          "color": "#ffffff",
          "name": "White"
        },
        {
          "slug": "black",
          "color": "#000000",
          "name": "Black"
        },
        {
          "slug": "gray-50",
          "color": "#f8fafc",
          "name": "Gray 50"
        },
        {
          "slug": "gray-100",
          "color": "#f1f5f9",
          "name": "Gray 100"
        },
        {
          "slug": "gray-200",
          "color": "#e2e8f0",
          "name": "Gray 200"
        },
        {
          "slug": "gray-300",
          "color": "#cbd5e1",
          "name": "Gray 300"
        },
        {
          "slug": "gray-400",
          "color": "#94a3b8",
          "name": "Gray 400"
        },
        {
          "slug": "gray-500",
          "color": "#64748b",
          "name": "Gray 500"
        },
        {
          "slug": "gray-600",
          "color": "#475569",
          "name": "Gray 600"
        },
        {
          "slug": "gray-700",
          "color": "#334155",
          "name": "Gray 700"
        },
        {
          "slug": "gray-800",
          "color": "#1e293b",
          "name": "Gray 800"
        },
        {
          "slug": "gray-900",
          "color": "#0f172a",
          "name": "Gray 900"
        },
        {
          "slug": "success",
          "color": "#10b981",
          "name": "Success"
        },
        {
          "slug": "warning",
          "color": "#f59e0b",
          "name": "Warning"
        },
        {
          "slug": "error",
          "color": "#ef4444",
          "name": "Error"
        },
        {
          "slug": "info",
          "color": "#3b82f6",
          "name": "Info"
        }
      ],
      "gradients": [
        {
          "slug": "primary-to-secondary",
          "gradient": "linear-gradient(135deg, #0e7490 0%, #0891b2 100%)",
          "name": "Primary to Secondary"
        },
        {
          "slug": "secondary-to-accent",
          "gradient": "linear-gradient(135deg, #0891b2 0%, #06b6d4 100%)",
          "name": "Secondary to Accent"
        },
        {
          "slug": "light-to-white",
          "gradient": "linear-gradient(135deg, #f8fafc 0%, #ffffff 100%)",
          "name": "Light to White"
        },
        {
          "slug": "dark-to-black",
          "gradient": "linear-gradient(135deg, #0f172a 0%, #000000 100%)",
          "name": "Dark to Black"
        }
      ],
      "duotone": [
        {
          "colors": [ "#0e7490", "#ffffff" ],
          "slug": "primary-white",
          "name": "Primary and White"
        },
        {
          "colors": [ "#0891b2", "#ffffff" ],
          "slug": "secondary-white",
          "name": "Secondary and White"
        },
        {
          "colors": [ "#06b6d4", "#ffffff" ],
          "slug": "accent-white",
          "name": "Accent and White"
        },
        {
          "colors": [ "#0f172a", "#ffffff" ],
          "slug": "dark-white",
          "name": "Dark and White"
        }
      ],
      "custom": true,
      "customGradient": true,
      "defaultPalette": false,
      "defaultGradients": false
    },
    "typography": {
      "fontSizes": [
        {
          "slug": "xs",
          "size": "0.75rem",
          "name": "Extra Small"
        },
        {
          "slug": "sm",
          "size": "0.875rem",
          "name": "Small"
        },
        {
          "slug": "base",
          "size": "1rem",
          "name": "Base"
        },
        {
          "slug": "lg",
          "size": "1.125rem",
          "name": "Large"
        },
        {
          "slug": "xl",
          "size": "1.25rem",
          "name": "Extra Large"
        },
        {
          "slug": "2xl",
          "size": "1.5rem",
          "name": "2X Large"
        },
        {
          "slug": "3xl",
          "size": "1.875rem",
          "name": "3X Large"
        },
        {
          "slug": "4xl",
          "size": "2.25rem",
          "name": "4X Large"
        },
        {
          "slug": "5xl",
          "size": "3rem",
          "name": "5X Large"
        },
        {
          "slug": "6xl",
          "size": "3.75rem",
          "name": "6X Large"
        },
        {
          "slug": "7xl",
          "size": "4.5rem",
          "name": "7X Large"
        },
        {
          "slug": "8xl",
          "size": "6rem",
          "name": "8X Large"
        },
        {
          "slug": "9xl",
          "size": "8rem",
          "name": "9X Large"
        }
      ],
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
          "slug": "system",
          "name": "System Font"
        },
        {
          "fontFamily": "'Inter', sans-serif",
          "slug": "inter",
          "name": "Inter"
        },
        {
          "fontFamily": "'Playfair Display', serif",
          "slug": "playfair",
          "name": "Playfair Display"
        },
        {
          "fontFamily": "'Montserrat', sans-serif",
          "slug": "montserrat",
          "name": "Montserrat"
        },
        {
          "fontFamily": "monospace",
          "slug": "monospace",
          "name": "Monospace"
        }
      ],
      "fontWeight": true,
      "fontStyle": true,
      "letterSpacing": true,
      "lineHeight": true,
      "textDecoration": true,
      "textTransform": true
    },
    "spacing": {
      "units": [ "px", "em", "rem", "vh", "vw", "%" ],
      "padding": true,
      "margin": true,
      "blockGap": true
    },
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "custom": {
      "spacing": {
        "small": "1rem",
        "medium": "2rem",
        "large": "4rem"
      },
      "typography": {
        "line-height": {
          "tiny": 1.15,
          "small": 1.2,
          "medium": 1.4,
          "normal": 1.6
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--gray-800)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "var(--wp--custom--typography--line-height--normal)"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        "typography": {
          "textDecoration": "none"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--secondary)"
          },
          "typography": {
            "textDecoration": "underline"
          }
        }
      },
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--playfair)",
          "fontSize": "var(--wp--preset--font-size--4xl)",
          "lineHeight": "var(--wp--custom--typography--line-height--tiny)",
          "fontWeight": "700"
        },
        "color": {
          "text": "var(--wp--preset--color--gray-900)"
        },
        "spacing": {
          "margin": {
            "top": "2rem",
            "bottom": "1.5rem"
          }
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--playfair)",
          "fontSize": "var(--wp--preset--font-size--3xl)",
          "lineHeight": "var(--wp--custom--typography--line-height--small)",
          "fontWeight": "700"
        },
        "color": {
          "text": "var(--wp--preset--color--gray-900)"
        },
        "spacing": {
          "margin": {
            "top": "2rem",
            "bottom": "1.5rem"
          }
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--playfair)",
          "fontSize": "var(--wp--preset--font-size--2xl)",
          "lineHeight": "var(--wp--custom--typography--line-height--small)",
          "fontWeight": "600"
        },
        "color": {
          "text": "var(--wp--preset--color--gray-900)"
        },
        "spacing": {
          "margin": {
            "top": "1.5rem",
            "bottom": "1rem"
          }
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--xl)",
          "lineHeight": "var(--wp--custom--typography--line-height--medium)",
          "fontWeight": "600"
        },
        "color": {
          "text": "var(--wp--preset--color--gray-900)"
        },
        "spacing": {
          "margin": {
            "top": "1.5rem",
            "bottom": "1rem"
          }
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--lg)",
          "lineHeight": "var(--wp--custom--typography--line-height--normal)",
          "fontWeight": "600"
        },
        "color": {
          "text": "var(--wp--preset--color--gray-900)"
        },
        "spacing": {
          "margin": {
            "top": "1.5rem",
            "bottom": "1rem"
          }
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--base)",
          "lineHeight": "var(--wp--custom--typography--line-height--normal)",
          "fontWeight": "600"
        },
        "color": {
          "text": "var(--wp--preset--color--gray-900)"
        },
        "spacing": {
          "margin": {
            "top": "1.5rem",
            "bottom": "0.5rem"
          }
        }
      }
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--base)",
          "fontWeight": "600"
        },
        "border": {
          "radius": "0.25rem"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "right": "1.5rem",
            "bottom": "0.75rem",
            "left": "1.5rem"
          }
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--secondary)",
            "text": "var(--wp--preset--color--white)"
          }
        },
        ":focus": {
          "color": {
            "background": "var(--wp--preset--color--secondary)",
            "text": "var(--wp--preset--color--white)"
          },
          "border": {
            "color": "var(--wp--preset--color--accent)",
            "width": "2px",
            "style": "solid"
          }
        }
      },
      "core/paragraph": {
        "spacing": {
          "margin": {
            "top": "1rem",
            "bottom": "1rem"
          }
        }
      },
      "core/list": {
        "spacing": {
          "margin": {
            "top": "1rem",
            "bottom": "1rem"
          },
          "padding": {
            "left": "1.5rem"
          }
        }
      },
      "core/table": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--sm)"
        }
      },
      "core/code": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--monospace)",
          "fontSize": "var(--wp--preset--font-size--sm)"
        },
        "color": {
          "background": "var(--wp--preset--color--gray-100)",
          "text": "var(--wp--preset--color--gray-800)"
        },
        "spacing": {
          "padding": {
            "top": "1rem",
            "right": "1.5rem",
            "bottom": "1rem",
            "left": "1.5rem"
          }
        },
        "border": {
          "radius": "0.25rem"
        }
      },
      "core/quote": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--playfair)",
          "fontSize": "var(--wp--preset--font-size--lg)",
          "fontStyle": "italic"
        },
        "color": {
          "text": "var(--wp--preset--color--gray-700)"
        },
        "border": {
          "color": "var(--wp--preset--color--primary)",
          "width": "0 0 0 4px",
          "style": "solid"
        },
        "spacing": {
          "padding": {
            "left": "1.5rem"
          },
          "margin": {
            "top": "2rem",
            "bottom": "2rem"
          }
        }
      },
      "core/pullquote": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--playfair)",
          "fontSize": "var(--wp--preset--font-size--xl)",
          "fontStyle": "italic"
        },
        "color": {
          "text": "var(--wp--preset--color--gray-700)"
        },
        "border": {
          "color": "var(--wp--preset--color--primary)",
          "width": "4px 0",
          "style": "solid"
        },
        "spacing": {
          "padding": {
            "top": "2rem",
            "bottom": "2rem"
          },
          "margin": {
            "top": "2.5rem",
            "bottom": "2.5rem"
          }
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    },
    {
      "name": "sidebar",
      "title": "Sidebar",
      "area": "sidebar"
    }
  ],
  "customTemplates": [
    {
      "name": "page-no-title",
      "title": "Page (No Title)",
      "postTypes": ["page"]
    },
    {
      "name": "page-full-width",
      "title": "Page (Full Width)",
      "postTypes": ["page"]
    },
    {
      "name": "page-with-sidebar",
      "title": "Page (With Sidebar)",
      "postTypes": ["page"]
    },
    {
      "name": "single-product-full-width",
      "title": "Single Product (Full Width)",
      "postTypes": ["product"]
    }
  ]
}