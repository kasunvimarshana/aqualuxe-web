# Set default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text files to be normalized
*.php text
*.css text
*.scss text
*.js text
*.json text
*.md text
*.txt text
*.xml text
*.svg text
*.yml text

# Declare files that will always have LF line endings on checkout
*.php eol=lf
*.css eol=lf
*.scss eol=lf
*.js eol=lf
*.json eol=lf
*.md eol=lf
*.txt eol=lf
*.xml eol=lf
*.svg eol=lf
*.yml eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.zip binary
*.gz binary