{
  "name": "aqualuxe-theme",
  "version": "1.0.0",
  "description": "A modular, multitenant WordPress theme for luxury aquatic retail",
  "keywords": [
    "wordpress",
    "theme",
    "woocommerce",
    "aquatic",
    "luxury",
    "modular",
    "responsive"
  ],
  "homepage": "https://github.com/kasunvimarshana/aqualuxe",
  "bugs": {
    "url": "https://github.com/kasunvimarshana/aqualuxe/issues"
  },
  "license": "GPL-2.0-or-later",
  "author": "AquaLuxe Team",
  "scripts": {
    "build": "npm run production",
    "dev": "npm run development",
    "development": "mix",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:php",
    "lint:js": "eslint assets/src/js --ext .js,.vue",
    "lint:css": "stylelint assets/src/scss/**/*.scss",
    "lint:php": "composer run-script phpcs || echo 'PHP CodeSniffer not available'",
    "lint:fix": "npm run lint:js -- --fix && npm run lint:css -- --fix",
    "format": "prettier --write assets/src/**/*.{js,vue,scss,css}",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "analyze": "mix --production --analyze",
    "clean": "rimraf assets/dist",
    "security:audit": "npm audit",
    "validate": "npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.6",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "browser-sync": "^3.0.4",
    "browser-sync-webpack-plugin": "^2.3.0",
    "css-loader": "^6.8.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "file-loader": "^6.2.0",
    "jest": "^29.7.0",
    "laravel-mix": "^6.0.49",
    "postcss": "^8.4.31",
    "postcss-loader": "^7.3.3",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.0.3",
    "resolve-url-loader": "^5.0.0",
    "rimraf": "^5.0.5",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "stylelint": "^14.16.1",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-standard": "^29.0.0",
    "tailwindcss": "^3.3.5",
    "webpack-bundle-analyzer": "^4.9.1"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "alpinejs": "^3.13.1",
    "gsap": "^3.12.2",
    "intersection-observer": "^0.12.2",
    "lazysizes": "^5.3.2",
    "swiper": "^11.0.5"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kasunvimarshana/aqualuxe.git"
  }
}
