{
  "name": "aqualuxe-theme",
  "version": "1.0.0",
  "description": "A premium, modular WordPress theme for luxury aquatic commerce",
  "main": "webpack.mix.js",
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "build": "npm run production",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint assets/src/js --ext .js --fix",
    "lint:css": "stylelint assets/src/scss/**/*.scss --fix"
  },
  "keywords": [
    "wordpress",
    "theme",
    "woocommerce",
    "aquatic",
    "luxury",
    "responsive",
    "modular",
    "multitenant",
    "multilingual",
    "multicurrency"
  ],
  "author": "AquaLuxe Development Team",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/kasunvimarshana/aqualuxe-web.git"
  },
  "bugs": {
    "url": "https://github.com/kasunvimarshana/aqualuxe-web/issues"
  },
  "homepage": "https://aqualuxe.com",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.6",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "eslint": "^8.51.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "file-loader": "^6.2.0",
    "imagemin": "^8.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^9.0.2",
    "imagemin-svgo": "^10.0.1",
    "imagemin-webp": "^7.0.0",
    "jest": "^29.7.0",
    "laravel-mix": "^6.0.49",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss": "^8.4.31",
    "postcss-loader": "^7.3.3",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-config-standard-scss": "^11.1.0",
    "tailwindcss": "^3.3.5",
    "url-loader": "^4.1.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "alpinejs": "^3.13.2",
    "gsap": "^3.12.2",
    "lazysizes": "^5.3.2",
    "swiper": "^10.3.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/js/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "assets/src/js/**/*.js",
      "!assets/src/js/vendor/**"
    ]
  },
  "eslintConfig": {
    "extends": [
      "standard"
    ],
    "env": {
      "browser": true,
      "es6": true,
      "jquery": true
    },
    "globals": {
      "wp": "readonly",
      "aqualuxe_ajax": "readonly",
      "Alpine": "readonly"
    }
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard-scss"
    ],
    "rules": {
      "at-rule-no-unknown": [
        true,
        {
          "ignoreAtRules": [
            "tailwind",
            "apply",
            "variants",
            "responsive",
            "screen"
          ]
        }
      ]
    }
  }
}
