{
  "name": "aqualuxe",
  "version": "1.0.0",
  "description": "Premium WordPress theme for luxury businesses with WooCommerce integration",
  "author": "NinjaTech AI",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "wordpress",
    "theme",
    "woocommerce",
    "luxury",
    "responsive"
  ],
  "homepage": "https://aqualuxe.example.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/example/aqualuxe"
  },
  "bugs": {
    "url": "https://github.com/example/aqualuxe/issues"
  },
  "browserslist": [
    "extends @wordpress/browserslist-config"
  ],
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "production": "mix --production",
    "optimize": "node ./bin/optimize-assets.js",
    "build": "npm run production && npm run optimize",
    "lint:css": "stylelint 'src/css/**/*.css'",
    "lint:js": "eslint 'src/js/**/*.js'",
    "lint:php": "composer run-script lint",
    "lint": "npm run lint:css && npm run lint:js && npm run lint:php",
    "format:css": "stylelint 'src/css/**/*.css' --fix",
    "format:js": "eslint 'src/js/**/*.js' --fix",
    "format": "npm run format:css && npm run format:js",
    "pot": "wp i18n make-pot . languages/aqualuxe.pot --exclude=node_modules,vendor,build",
    "zip": "node ./bin/create-zip.js",
    "test": "jest"
  },
  "devDependencies": {
    "@babel/core": "^7.22.5",
    "@babel/preset-env": "^7.22.5",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.9",
    "@wordpress/browserslist-config": "^5.16.0",
    "@wordpress/eslint-plugin": "^14.7.0",
    "archiver": "^5.3.1",
    "autoprefixer": "^10.4.14",
    "browser-sync": "^2.29.3",
    "browser-sync-webpack-plugin": "^2.3.0",
    "chalk": "^4.1.2",
    "cross-env": "^7.0.3",
    "cssnano": "^6.0.1",
    "eslint": "^8.43.0",
    "imagemin": "^8.0.1",
    "imagemin-gifsicle": "^7.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^9.0.2",
    "imagemin-svgo": "^10.0.1",
    "imagemin-webp": "^8.0.0",
    "jest": "^29.5.0",
    "laravel-mix": "^6.0.49",
    "postcss": "^8.4.24",
    "postcss-import": "^15.1.0",
    "postcss-nested": "^6.0.1",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.63.6",
    "sass-loader": "^13.3.2",
    "stylelint": "^15.9.0",
    "stylelint-config-standard": "^33.0.0",
    "tailwindcss": "^3.3.2"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.12.3",
    "@alpinejs/focus": "^3.12.3",
    "@alpinejs/persist": "^3.12.3",
    "alpinejs": "^3.12.3"
  }
}