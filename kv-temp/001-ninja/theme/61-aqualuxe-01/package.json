{
  "name": "aqualuxe",
  "version": "1.0.0",
  "description": "AquaLuxe - Premium WordPress Theme for Aquatic Businesses",
  "main": "index.js",
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "lint": "eslint assets/src/js --ext .js",
    "lint:fix": "eslint assets/src/js --ext .js --fix",
    "stylelint": "stylelint assets/src/scss/**/*.scss",
    "stylelint:fix": "stylelint assets/src/scss/**/*.scss --fix",
    "test": "jest",
    "pot": "wp i18n make-pot . languages/aqualuxe.pot --exclude=node_modules,vendor,assets/dist",
    "zip": "node ./build/zip.js"
  },
  "keywords": [
    "wordpress",
    "theme",
    "woocommerce",
    "aquatic",
    "ecommerce"
  ],
  "author": "AquaLuxe",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.22.20",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "browser-sync": "^2.29.3",
    "browser-sync-webpack-plugin": "^2.3.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "cssnano": "^6.0.1",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "file-loader": "^6.2.0",
    "imagemin-webpack-plugin": "^2.4.2",
    "jest": "^29.7.0",
    "laravel-mix": "^6.0.49",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss": "^8.4.31",
    "postcss-import": "^15.1.0",
    "postcss-loader": "^7.3.3",
    "postcss-preset-env": "^9.1.4",
    "prettier": "^3.0.3",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.68.0",
    "sass-loader": "^13.3.2",
    "stylelint": "^15.10.3",
    "stylelint-config-standard-scss": "^11.0.0",
    "tailwindcss": "^3.3.3",
    "terser-webpack-plugin": "^5.3.9",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.13.0",
    "@alpinejs/focus": "^3.13.0",
    "@alpinejs/persist": "^3.13.0",
    "alpinejs": "^3.13.0",
    "gsap": "^3.12.2",
    "swiper": "^10.3.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}