{
  "name": "aqualuxe-theme",
  "version": "1.0.0",
  "description": "AquaLuxe WordPress theme - Modular, multitenant, multivendor, multilingual, multicurrency, mobile-first WordPress theme",
  "main": "webpack.mix.js",
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "build": "npm run production",
    "lint:js": "eslint assets/src/js --ext .js --fix",
    "lint:css": "stylelint assets/src/scss/**/*.scss --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "analyze": "mix --production --analyze"
  },
  "keywords": [
    "wordpress",
    "theme",
    "ecommerce",
    "woocommerce",
    "multitenant",
    "multivendor",
    "multilingual",
    "multicurrency",
    "responsive",
    "modular",
    "tailwind"
  ],
  "author": "Kasun Vimarshana",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "eslint": "^8.53.0",
    "laravel-mix": "^6.0.49",
    "postcss": "^8.4.31",
    "postcss-loader": "^7.3.3",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "stylelint": "^15.11.0",
    "stylelint-config-standard-scss": "^11.1.0",
    "tailwindcss": "^3.3.5",
    "webpack": "^5.89.0"
  },
  "dependencies": {
    "alpinejs": "^3.13.3",
    "swiper": "^11.0.4"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}