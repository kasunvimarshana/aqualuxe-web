{
  "name": "aqualuxe-wordpress-theme",
  "version": "1.0.0",
  "description": "AquaLuxe - Premium modular WordPress theme for aquatic luxury commerce",
  "author": "Kasun Vimarshana <kasun@example.com>",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/kasunvimarshana/aqualuxe-web.git"
  },
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "build": "npm run production",
    "lint:js": "eslint assets/src/js/**/*.js --fix",
    "lint:css": "stylelint assets/src/css/**/*.css --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "analyze": "npm run production -- --analyze"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "axios": "^1.6.0",
    "browser-sync": "^2.29.3",
    "browser-sync-webpack-plugin": "^2.3.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.54.0",
    "eslint-config-standard": "^17.1.0",
    "jest": "^29.7.0",
    "laravel-mix": "^6.0.49",
    "lodash": "^4.17.21",
    "postcss": "^8.4.31",
    "postcss-import": "^15.1.0",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "tailwindcss": "^3.3.5",
    "vue-template-compiler": "^2.7.14"
  },
  "dependencies": {
    "gsap": "^3.12.2",
    "swiper": "^11.0.4"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie <= 11"
  ],
  "keywords": [
    "wordpress",
    "theme",
    "woocommerce",
    "multilingual",
    "multicurrency",
    "responsive",
    "modular",
    "accessibility",
    "seo",
    "performance"
  ]
}