{
    "name": "aqualuxe-theme",
    "version": "1.2.0",
    "description": "Premium WordPress theme for AquaLuxe - Bringing elegance to aquatic life globally",
    "author": "AquaLuxe Development Team",
    "license": "GPL-2.0-or-later",
    "private": true,
    "scripts": {
        "dev": "npm run development",
        "development": "mix",
        "watch": "mix watch",
        "watch-poll": "mix watch -- --watch-options-poll=1000",
        "hot": "mix watch --hot",
        "prod": "npm run production",
        "production": "mix --production",
        "build": "npm run production",
        "clean": "rimraf assets/dist",
        "lint:js": "eslint assets/src/js --ext .js",
        "lint:css": "stylelint 'assets/src/scss/**/*.scss'",
        "test": "jest",
        "analyze": "mix --production --analyze"
    },
    "devDependencies": {
        "@babel/core": "^7.22.0",
        "@babel/preset-env": "^7.22.0",
        "@fortawesome/fontawesome-free": "^7.0.1",
        "@tailwindcss/aspect-ratio": "^0.4.2",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/typography": "^0.5.9",
        "autoprefixer": "^10.4.14",
        "babel-loader": "^9.1.0",
        "browser-sync": "^2.29.0",
        "browser-sync-webpack-plugin": "^2.3.0",
        "css-loader": "^6.8.0",
        "eslint": "^8.43.0",
        "file-loader": "^6.2.0",
        "imagemin": "^8.0.1",
        "imagemin-mozjpeg": "^10.0.0",
        "imagemin-pngquant": "^9.0.2",
        "imagemin-webp": "^7.0.0",
        "jest": "^29.5.0",
        "laravel-mix": "^6.0.49",
        "postcss": "^8.4.24",
        "postcss-loader": "^7.3.0",
        "resolve-url-loader": "^5.0.0",
        "rimraf": "^5.0.1",
        "sass": "^1.63.0",
        "sass-loader": "^13.3.0",
        "tailwindcss": "^3.3.0",
        "webpack": "^5.88.0",
        "webpack-bundle-analyzer": "^4.9.0"
    },
    "dependencies": {
        "@glidejs/glide": "^3.6.0",
        "aos": "^2.3.4",
        "d3": "^7.9.0",
        "gsap": "^3.13.0",
        "lottie-web": "^5.12.0",
        "photoswipe": "^5.3.8",
        "simplebar": "^6.2.5",
        "swiper": "^9.4.0",
        "three": "^0.180.0",
        "vanilla-lazyload": "^17.8.3"
    },
    "browserslist": [
        "> 1%",
        "last 2 versions",
        "not dead"
    ],
    "engines": {
        "node": ">=16.0.0",
        "npm": ">=8.0.0"
    }
}
