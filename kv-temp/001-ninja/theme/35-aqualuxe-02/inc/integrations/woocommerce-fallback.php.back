	}

	/**
	 * Get shortcode fallback notice.
	 *
	 * @param string $shortcode_name Shortcode name.
	 * @return string Fallback notice.
	 */
	private function get_shortcode_fallback_notice( $shortcode_name ) {
		$fallback_page_id = $this->get_fallback_shop_page_id();
		$shop_url = $fallback_page_id ? get_permalink( $fallback_page_id ) : home_url();
		
		ob_start();
		?>
		<div class="aqualuxe-shortcode-fallback">
			<div class="aqualuxe-shortcode-fallback-content">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="10"></circle>
					<line x1="12" y1="8" x2="12" y2="12"></line>
					<line x1="12" y1="16" x2="12.01" y2="16"></line>
				</svg>
				<p>
					<?php
					/* translators: %s: Shortcode name */
					echo wp_kses_post( sprintf( __( 'The "%s" shortcode requires WooCommerce to be active.', 'aqualuxe' ), $shortcode_name ) );
					?>
				</p>
				<a href="<?php echo esc_url( $shop_url ); ?>" class="aqualuxe-shortcode-fallback-button">
					<?php esc_html_e( 'Visit Shop', 'aqualuxe' ); ?>
				</a>
			</div>
		</div>
		<?php
		return ob_get_clean();
	}

	/**
	 * Register fallback widgets.
	 */
	public function register_fallback_widgets() {
		// Register fallback widgets.
		register_widget( 'AquaLuxe_Products_Widget_Fallback' );
		register_widget( 'AquaLuxe_Product_Categories_Widget_Fallback' );
		register_widget( 'AquaLuxe_Product_Search_Widget_Fallback' );
	}

	/**
	 * Filter WooCommerce menu items.
	 *
	 * @param array    $items Menu items.
	 * @param stdClass $args  Menu arguments.
	 * @return array Modified menu items.
	 */
	public function filter_woocommerce_menu_items( $items, $args ) {
		$fallback_page_id = $this->get_fallback_shop_page_id();
		$shop_url = $fallback_page_id ? get_permalink( $fallback_page_id ) : home_url();
		
		foreach ( $items as $key => $item ) {
			// Check if this is a WooCommerce endpoint.
			$wc_endpoints = array( 'shop', 'cart', 'checkout', 'my-account', 'product' );
			
			foreach ( $wc_endpoints as $endpoint ) {
				if ( strpos( $item->url, '/' . $endpoint . '/' ) !== false ) {
					// Replace the URL with the fallback shop page.
					$items[ $key ]->url = $shop_url;
					break;
				}
			}
		}
		
		return $items;
	}
}

// Initialize the class.
new AquaLuxe_WooCommerce_Fallback();

/**
 * AquaLuxe Products Widget Fallback
 */
class AquaLuxe_Products_Widget_Fallback extends WP_Widget {

	/**
	 * Constructor.
	 */
	public function __construct() {
		parent::__construct(
			'aqualuxe_products_widget_fallback',
			esc_html__( 'AquaLuxe Products', 'aqualuxe' ),
			array(
				'description' => esc_html__( 'Display products (requires WooCommerce).', 'aqualuxe' ),
			)
		);
	}

	/**
	 * Widget output.
	 *
	 * @param array $args     Widget arguments.
	 * @param array $instance Widget instance.
	 */
	public function widget( $args, $instance ) {
		$title = ! empty( $instance['title'] ) ? $instance['title'] : esc_html__( 'Products', 'aqualuxe' );
		$title = apply_filters( 'widget_title', $title, $instance, $this->id_base );
		
		echo wp_kses_post( $args['before_widget'] );
		
		if ( $title ) {
			echo wp_kses_post( $args['before_title'] . $title . $args['after_title'] );
		}
		
		echo '<div class="aqualuxe-widget-fallback">';
		echo '<p>' . esc_html__( 'This widget requires WooCommerce to be active.', 'aqualuxe' ) . '</p>';
		echo '</div>';
		
		echo wp_kses_post( $args['after_widget'] );
	}

	/**
	 * Widget form.
	 *
	 * @param array $instance Widget instance.
	 * @return void
	 */
	public function form( $instance ) {
		$title = ! empty( $instance['title'] ) ? $instance['title'] : esc_html__( 'Products', 'aqualuxe' );
		?>
		<p>
			<label for="<?php echo esc_attr( $this->get_field_id( 'title' ) ); ?>"><?php esc_html_e( 'Title:', 'aqualuxe' ); ?></label>
			<input class="widefat" id="<?php echo esc_attr( $this->get_field_id( 'title' ) ); ?>" name="<?php echo esc_attr( $this->get_field_name( 'title' ) ); ?>" type="text" value="<?php echo esc_attr( $title ); ?>">
		</p>
		<p>
			<?php esc_html_e( 'Note: This widget requires WooCommerce to be active.', 'aqualuxe' ); ?>
		</p>
		<?php
	}

	/**
	 * Widget update.
	 *
	 * @param array $new_instance New widget instance.
	 * @param array $old_instance Old widget instance.
	 * @return array Updated widget instance.
	 */
	public function update( $new_instance, $old_instance ) {
		$instance = array();
		$instance['title'] = ! empty( $new_instance['title'] ) ? sanitize_text_field( $new_instance['title'] ) : '';
		return $instance;
	}
}

/**
 * AquaLuxe Product Categories Widget Fallback
