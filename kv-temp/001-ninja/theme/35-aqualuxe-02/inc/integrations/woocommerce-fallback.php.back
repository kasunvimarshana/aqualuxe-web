<?php
/**
 * WooCommerce fallback functionality
 *
 * This file provides graceful fallbacks when WooCommerce is not active.
 * It ensures the theme maintains a consistent UX and prevents fatal errors.
 *
 * @package AquaLuxe
 * @since 1.0.0
 */

// Exit if accessed directly.
if ( ! defined( 'ABSPATH' ) ) {
	exit;
}

// Return if WooCommerce is active (this file should only load when WC is inactive).
if ( class_exists( 'WooCommerce' ) ) {
	return;
}

/**
 * AquaLuxe WooCommerce Fallback Class
 */
class AquaLuxe_WooCommerce_Fallback {

	/**
	 * Constructor.
	 */
	public function __construct() {
		// Setup hooks.
		$this->setup_hooks();
	}

	/**
	 * Setup hooks.
	 */
	private function setup_hooks() {
		// Handle WooCommerce template redirects.
		add_action( 'template_redirect', array( $this, 'handle_woocommerce_endpoints' ) );

		// Add fallback shop page.
		add_action( 'init', array( $this, 'register_fallback_shop_page' ) );

		// Add fallback header icons.
		add_action( 'aqualuxe_header_icons', array( $this, 'header_shop_icon' ) );
		
		// Add fallback shortcodes.
		add_shortcode( 'products', array( $this, 'products_shortcode_fallback' ) );
		add_shortcode( 'product_page', array( $this, 'product_page_shortcode_fallback' ) );
		add_shortcode( 'product_category', array( $this, 'product_category_shortcode_fallback' ) );
		add_shortcode( 'product_categories', array( $this, 'product_categories_shortcode_fallback' ) );
		add_shortcode( 'add_to_cart', array( $this, 'add_to_cart_shortcode_fallback' ) );
		add_shortcode( 'add_to_cart_url', array( $this, 'add_to_cart_url_shortcode_fallback' ) );
		add_shortcode( 'recent_products', array( $this, 'recent_products_shortcode_fallback' ) );
		add_shortcode( 'featured_products', array( $this, 'featured_products_shortcode_fallback' ) );
		add_shortcode( 'sale_products', array( $this, 'sale_products_shortcode_fallback' ) );
		add_shortcode( 'best_selling_products', array( $this, 'best_selling_products_shortcode_fallback' ) );
		add_shortcode( 'top_rated_products', array( $this, 'top_rated_products_shortcode_fallback' ) );
		add_shortcode( 'related_products', array( $this, 'related_products_shortcode_fallback' ) );
		
		// Add fallback widgets.
		add_action( 'widgets_init', array( $this, 'register_fallback_widgets' ) );
		
		// Add fallback menu items.
		add_filter( 'wp_nav_menu_objects', array( $this, 'filter_woocommerce_menu_items' ), 10, 2 );
	}

	/**
	 * Handle WooCommerce endpoints.
	 * Redirects users trying to access WooCommerce pages when WooCommerce is not active.
	 */
	public function handle_woocommerce_endpoints() {
		global $wp_query;

		// Check if we're on a potential WooCommerce endpoint.
		$wc_endpoints = array(
			'shop',
			'product',
			'product-category',
			'product-tag',
			'cart',
			'checkout',
			'my-account',
			'wc-api',
			'add-to-cart',
		);

		$is_wc_endpoint = false;

		// Check if current query is for a WooCommerce endpoint.
		foreach ( $wc_endpoints as $endpoint ) {
			if ( isset( $wp_query->query_vars[ $endpoint ] ) ) {
				$is_wc_endpoint = true;
				break;
			}
		}

		// Also check for WooCommerce taxonomies.
		$wc_taxonomies = array( 'product_cat', 'product_tag' );
		foreach ( $wc_taxonomies as $taxonomy ) {
			if ( is_tax( $taxonomy ) ) {
				$is_wc_endpoint = true;
				break;
			}
		}

		// Check for shop page.
		if ( is_page() && get_the_ID() === $this->get_fallback_shop_page_id() ) {
			$is_wc_endpoint = true;
		}

		// If we're on a WooCommerce endpoint, handle the fallback.
		if ( $is_wc_endpoint ) {
			$this->display_woocommerce_fallback();
			return;
		}
	}

	/**
	 * Display WooCommerce fallback content.
	 */
	private function display_woocommerce_fallback() {
		// Get fallback shop page ID.
		$fallback_page_id = $this->get_fallback_shop_page_id();

		// If we have a fallback page, redirect to it.
		if ( $fallback_page_id && $fallback_page_id !== get_the_ID() ) {
			wp_safe_redirect( get_permalink( $fallback_page_id ) );
			exit;
		}

		// Otherwise, continue with the current page but display a notice.
		add_action( 'aqualuxe_before_main_content', array( $this, 'display_woocommerce_notice' ) );
	}

	/**
	 * Display WooCommerce notice.
	 */
	public function display_woocommerce_notice() {
		$message = get_theme_mod( 'aqualuxe_fallback_message', esc_html__( 'Our shop is currently being updated. Please check back soon.', 'aqualuxe' ) );
		?>
		<div class="aqualuxe-woocommerce-notice">
			<div class="aqualuxe-woocommerce-notice-content">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="10"></circle>
					<line x1="12" y1="8" x2="12" y2="12"></line>
					<line x1="12" y1="16" x2="12.01" y2="16"></line>
				</svg>
				<p><?php echo wp_kses_post( $message ); ?></p>
			</div>
		</div>
		<?php
	}

	/**
	 * Register fallback shop page.
	 */
	public function register_fallback_shop_page() {
		// Check if we already have a fallback shop page.
		$fallback_page_id = $this->get_fallback_shop_page_id();
		
		// If we don't have a fallback page, create one.
		if ( ! $fallback_page_id ) {
			// Create fallback shop page.
			$page_id = wp_insert_post(
				array(
					'post_title'     => esc_html__( 'Shop', 'aqualuxe' ),
					'post_content'   => wp_kses_post( $this->get_fallback_shop_content() ),
					'post_status'    => 'publish',
					'post_type'      => 'page',
					'comment_status' => 'closed',
				)
			);

			// Save fallback shop page ID.
			if ( $page_id && ! is_wp_error( $page_id ) ) {
				set_theme_mod( 'aqualuxe_fallback_shop_page', $page_id );
			}
		}
	}

	/**
	 * Get fallback shop page ID.
	 *
	 * @return int Fallback shop page ID.
	 */
	private function get_fallback_shop_page_id() {
		$fallback_page_id = get_theme_mod( 'aqualuxe_fallback_shop_page', 0 );
		
		// Verify the page exists.
		if ( $fallback_page_id && 'page' === get_post_type( $fallback_page_id ) ) {
			return $fallback_page_id;
		}
		
		return 0;
	}

