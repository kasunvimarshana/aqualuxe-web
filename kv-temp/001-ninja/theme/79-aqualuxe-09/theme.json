{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": { "contentSize": "720px", "wideSize": "1200px" },
    "color": {
      "palette": [
        { "slug": "primary", "name": "Primary", "color": "#0ea5e9" },
        { "slug": "slate-900", "name": "Slate 900", "color": "#0f172a" },
        { "slug": "slate-100", "name": "Slate 100", "color": "#f1f5f9" }
      ],
      "defaultPalette": true,
      "link": true
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "system-sans",
          "name": "System Sans",
          "fontFamily": "ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, 'Apple Color Emoji', 'Segoe UI Emoji'"
        }
      ],
      "defaultFontSizes": true
    },
    "spacing": {
      "units": ["px", "em", "rem", "%"],
      "blockGap": true
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)"
    },
    "elements": {
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" }
      }
    }
  }
}
