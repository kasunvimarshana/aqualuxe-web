{
  "name": "aqualuxe-theme",
  "version": "1.0.21",
  "private": true,
  "description": "AquaLuxe modular WordPress theme assets",
  "scripts": {
    "dev": "mix",
    "watch": "mix watch",
  "prebuild": "node scripts/clean-dist.js",
    "build": "cross-env NODE_ENV=production mix --production",
    "postbuild": "node scripts/fix-manifest.js",
  "pot": "wp i18n make-pot . languages/aqualuxe.pot --domain=aqualuxe",
  "pot:wp-pot": "wp-pot --src '**/*.{php}' --domain aqualuxe --package 'AquaLuxe' --dest languages/aqualuxe.pot"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "laravel-mix": "^6.0.49",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.9",
  "wp-pot": "^1.10.0",
  "@wordpress/i18n-tools": "^4.36.0"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "gsap": "^3.12.5",
    "three": "^0.160.0"
  }
}
