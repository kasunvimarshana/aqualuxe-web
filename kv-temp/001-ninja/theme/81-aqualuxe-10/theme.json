{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "brand", "name": "Brand Cyan", "color": "#0ea5e9" },
        { "slug": "slate-900", "name": "Slate 900", "color": "#0f172a" },
        { "slug": "white", "name": "White", "color": "#ffffff" }
      ]
    },
    "layout": {
      "contentSize": "80rem",
      "wideSize": "90rem"
    },
    "typography": {
      "lineHeight": true,
      "fontFamilies": [
        {
          "slug": "system-sans",
          "name": "System Sans",
          "fontFamily": "ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, Noto Sans, Helvetica Neue, Arial, sans-serif"
        }
      ]
    }
  },
  "styles": {
    "typography": { "fontFamily": "ui-sans-serif" },
    "color": { "background": "#ffffff", "text": "#0f172a" }
  }
}
