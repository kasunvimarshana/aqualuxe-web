{
  "name": "aqualuxe-theme",
  "version": "1.0.0",
  "private": true,
  "description": "AquaLuxe WordPress theme build tooling",
  "scripts": {
    "dev": "cross-env NODE_ENV=development mix",
    "watch": "cross-env NODE_ENV=development mix watch",
    "build": "cross-env NODE_ENV=production mix --production",
    "lint:php": "php -l **/*.php",
    "postinstall": "node -e \"try{require('fs').mkdirSync('assets/dist',{recursive:true})}catch(e){}\""
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "laravel-mix": "^6.0.49",
    "postcss": "^8.4.47",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^3.4.13"
  },
  "dependencies": {
    "three": "^0.168.0",
    "gsap": "^3.12.5",
    "d3": "^7.9.0"
  }
}
