{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "primary",
          "color": "#0077b6",
          "name": "Primary"
        },
        {
          "slug": "secondary",
          "color": "#00b4d8",
          "name": "Secondary"
        },
        {
          "slug": "accent",
          "color": "#48cae4",
          "name": "Accent"
        },
        {
          "slug": "dark",
          "color": "#03045e",
          "name": "Dark"
        },
        {
          "slug": "light",
          "color": "#caf0f8",
          "name": "Light"
        },
        {
          "slug": "white",
          "color": "#ffffff",
          "name": "White"
        },
        {
          "slug": "black",
          "color": "#000814",
          "name": "Black"
        },
        {
          "slug": "gold",
          "color": "#d4af37",
          "name": "Gold"
        }
      ],
      "gradients": [
        {
          "slug": "ocean-gradient",
          "gradient": "linear-gradient(135deg, #0077b6 0%, #00b4d8 100%)",
          "name": "Ocean Gradient"
        },
        {
          "slug": "luxury-gradient",
          "gradient": "linear-gradient(135deg, #03045e 0%, #0077b6 100%)",
          "name": "Luxury Gradient"
        },
        {
          "slug": "gold-gradient",
          "gradient": "linear-gradient(135deg, #d4af37 0%, #f5f5f5 100%)",
          "name": "Gold Gradient"
        }
      ],
      "custom": true,
      "customGradient": true,
      "link": true,
      "defaultPalette": false,
      "defaultGradients": false
    },
    "typography": {
      "fontSizes": [
        {
          "slug": "small",
          "size": "0.875rem",
          "name": "Small"
        },
        {
          "slug": "medium",
          "size": "1rem",
          "name": "Medium"
        },
        {
          "slug": "large",
          "size": "1.125rem",
          "name": "Large"
        },
        {
          "slug": "x-large",
          "size": "1.5rem",
          "name": "Extra Large"
        },
        {
          "slug": "xx-large",
          "size": "2rem",
          "name": "XX Large"
        },
        {
          "slug": "xxx-large",
          "size": "3rem",
          "name": "XXX Large"
        }
      ],
      "fontFamilies": [
        {
          "fontFamily": "&quot;Playfair Display&quot;, serif",
          "slug": "heading",
          "name": "Heading"
        },
        {
          "fontFamily": "&quot;Montserrat&quot;, sans-serif",
          "slug": "body",
          "name": "Body"
        }
      ],
      "customFontSize": true
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "units": ["px", "em", "rem", "%", "vw", "vh"]
    },
    "layout": {
      "contentSize": "1140px",
      "wideSize": "1320px"
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "custom": {
      "spacing": {
        "small": "1rem",
        "medium": "2rem",
        "large": "4rem"
      },
      "typography": {
        "line-height": {
          "small": 1.2,
          "medium": 1.5,
          "large": 1.8
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--black)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "var(--wp--custom--typography--line-height--medium)"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--xxx-large)",
          "lineHeight": "var(--wp--custom--typography--line-height--small)"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--xx-large)",
          "lineHeight": "var(--wp--custom--typography--line-height--small)"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "lineHeight": "var(--wp--custom--typography--line-height--small)"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--large)",
          "lineHeight": "var(--wp--custom--typography--line-height--small)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      }
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "border": {
          "radius": "4px"
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--medium)"
        }
      },
      "core/heading": {
        "color": {
          "text": "var(--wp--preset--color--dark)"
        }
      }
    }
  }
}