{
  "name": "aqualuxe-wordpress-theme",
  "version": "1.0.0",
  "description": "Premium WordPress + WooCommerce child theme for ornamental fish businesses",
  "main": "functions.php",
  "scripts": {
    "dev": "docker-compose up -d",
    "stop": "docker-compose down",
    "logs": "docker-compose logs -f",
    "build": "npm run build:css && npm run build:js",
    "build:css": "sass assets/scss/main.scss:style.css --style=compressed",
    "build:js": "webpack --mode=production",
    "watch": "npm run watch:css & npm run watch:js",
    "watch:css": "sass --watch assets/scss/main.scss:style.css",
    "watch:js": "webpack --mode=development --watch",
    "lint": "npm run lint:php && npm run lint:css && npm run lint:js",
    "lint:php": "phpcs --standard=WordPress .",
    "lint:css": "stylelint assets/css/**/*.css",
    "lint:js": "eslint assets/js/**/*.js",
    "test": "phpunit",
    "zip": "zip -r aqualuxe.zip . -x '*.git*' 'node_modules/*' 'docker-compose.yml' 'package*.json' 'webpack.config.js' '.env*' 'logs/*' 'mysql-*/*' 'nginx/*' '*.md'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kasunvimarshana/aqualuxe.git"
  },
  "keywords": [
    "wordpress",
    "woocommerce",
    "theme",
    "child-theme",
    "e-commerce",
    "ornamental-fish",
    "aquarium",
    "responsive",
    "seo",
    "performance"
  ],
  "author": {
    "name": "Kasun Vimarshana",
    "email": "kasunvimarshana@gmail.com",
    "url": "https://github.com/kasunvimarshana"
  },
  "license": "GPL-2.0-or-later",
  "bugs": {
    "url": "https://github.com/kasunvimarshana/aqualuxe/issues"
  },
  "homepage": "https://github.com/kasunvimarshana/aqualuxe#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "eslint": "^8.50.0",
    "mini-css-extract-plugin": "^2.7.6",
    "sass": "^1.69.0",
    "sass-loader": "^13.3.2",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "jquery": "^3.7.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "wordpress": {
    "requires": "5.0",
    "tested": "6.4",
    "requires_php": "7.4"
  },
  "woocommerce": {
    "requires": "5.0",
    "tested": "8.3"
  }
}