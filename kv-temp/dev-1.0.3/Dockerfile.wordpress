FROM wordpress:6.8-php8.3-apache

# Set timezone
ENV TZ=UTC
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# Install common dev tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    unzip sudo git nano less mariadb-client curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Update CA certificates
RUN update-ca-certificates

# PHP extensions
RUN docker-php-ext-install -j$(nproc) bcmath exif

# WP-CLI
RUN curl -O https://raw.githubusercontent.com/wp-cli/builds/gh-pages/phar/wp-cli.phar \
    && chmod +x wp-cli.phar \
    && mv wp-cli.phar /usr/local/bin/wp

# Create mu-plugins directory in source location
RUN mkdir -p /usr/src/wordpress/wp-content/mu-plugins

# Copy mu-plugins (will be moved by WordPress entrypoint)
COPY ./mu-plugins /usr/src/wordpress/wp-content/mu-plugins

# Apache configuration
RUN echo "ServerName localhost" > /etc/apache2/conf-available/server-name.conf \
    && a2enconf server-name

# Set proper permissions
RUN chown -R www-data:www-data /usr/src/wordpress

# Health check
HEALTHCHECK --interval=30s --timeout=3s \
    CMD curl -f http://localhost:80/ || exit 1